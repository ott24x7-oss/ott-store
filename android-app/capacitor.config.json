{
  "appId": "com.ott24x7.app",
  "appName": "OTT24x7",
  "webDir": "www",
  "server": {
    "url": "https://ott24x7.com/app",
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": ["ott24x7.com", "*.ott24x7.com"]
  },
  "android": {
    "backgroundColor": "#0a0b16",
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 600,
      "backgroundColor": "#110d26",
      "showSpinner": false,
      "androidSplashResourceName": "splash"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0b16"
    }
  }
}
