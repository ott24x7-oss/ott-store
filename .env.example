# Copy this file to .env and fill in your values
PORT=3000
BASE_URL=https://store.watshop.in
SESSION_SECRET=change-me-to-a-random-32-char-hex-string
ADMIN_PASSWORD=admin123!

# Razorpay (leave blank to disable)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP Email (leave blank to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@store.watshop.in

# OTT24x7 Telegram-bot reseller API — sell the bot's catalog here with auto-delivery.
# Get the token from the bot's reseller panel; URL is the bot's public domain.
# Leave blank to disable the bot integration.
BOT_API_URL=
BOT_API_TOKEN=

# ── Rent Control licensing (leave BLANK for the flagship / owner deploy) ──────
# Only set these on a RENTED instance so its admin locks if the rent lapses past
# the grace period. The customer storefront always keeps running, and it fails
# open if the panel is unreachable. Get LICENCE_KEY from your Rent Control panel;
# LICENCE_SECRET must match the panel's LICENCE_SECRET.
LICENCE_SERVER=
LICENCE_KEY=
LICENCE_SECRET=

NODE_ENV=production
